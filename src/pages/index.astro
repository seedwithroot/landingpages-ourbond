<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>OurBond — Pages</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; background: #f3f4f6; margin: 0; padding: 2rem; }
    h1 { font-size: 1.125rem; font-weight: 700; color: #111; margin: 0 0 0.25rem; }
    .subtitle { font-size: 0.8125rem; color: #6b7280; margin: 0 0 2rem; }
    a.dev-link { font-size: 0.75rem; color: #2563eb; text-decoration: underline; }
    .section { margin-bottom: 2.5rem; }
    .section-title { font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #9ca3af; margin: 0 0 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid #e5e7eb; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.625rem; }
    a.card { display: block; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.75rem 1rem; text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s; }
    a.card:hover { border-color: #2563eb; box-shadow: 0 0 0 3px #dbeafe; }
    a.card .label { font-size: 0.9375rem; font-weight: 600; color: #111; display: block; margin-bottom: 0.2rem; }
    a.card .url { font-size: 0.75rem; color: #6b7280; font-family: monospace; }
    .section--go-live { background: #0f172a; border-radius: 12px; padding: 1.25rem 1.5rem 1.5rem; margin-bottom: 2.5rem; }
    .section--go-live .section-title { color: #38bdf8; border-bottom-color: #1e3a5f; }
    .section--go-live a.card { background: #1e293b; border-color: #334155; }
    .section--go-live a.card:hover { border-color: #38bdf8; box-shadow: 0 0 0 3px #0c4a6e; }
    .section--go-live a.card .label { color: #f1f5f9; }
    .section--go-live a.card .url { color: #64748b; }
    .section--go-live .go-live-badge { display: inline-block; font-size: 0.625rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; background: #38bdf8; color: #0f172a; border-radius: 4px; padding: 0.15rem 0.5rem; margin-right: 0.5rem; vertical-align: middle; }
    /* Review section */
    .section--review { background: #fefce8; border: 1px solid #fde047; border-radius: 12px; padding: 1.25rem 1.5rem 1.5rem; margin-bottom: 2.5rem; }
    .section--review .section-title { color: #854d0e; border-bottom-color: #fde047; }
    .section--review .review-badge { display: inline-block; font-size: 0.625rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; background: #f59e0b; color: #fff; border-radius: 4px; padding: 0.15rem 0.5rem; margin-right: 0.5rem; vertical-align: middle; }
    .section--review a.card { background: #fff; border-color: #fde68a; }
    .section--review a.card:hover { border-color: #f59e0b; box-shadow: 0 0 0 3px #fef9c3; }
    .section--review a.card .label { color: #111; }
    .section--review a.card .url { color: #92400e; }
    .section--review .card-actions { display: flex; gap: 0.5rem; margin-top: 0.5rem; }
    .section--review .card-actions a { font-size: 0.7rem; font-weight: 600; padding: 0.25rem 0.65rem; border-radius: 5px; text-decoration: none; transition: background 0.15s; }
    .section--review .card-actions .btn-view { background: #e5e7eb; color: #374151; }
    .section--review .card-actions .btn-view:hover { background: #d1d5db; }
    .section--review .card-actions .btn-review { background: #f59e0b; color: #fff; }
    .section--review .card-actions .btn-review:hover { background: #d97706; }
  </style>
</head>
