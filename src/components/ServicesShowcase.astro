---
interface Service {
  name: string;
  description?: string;
  howItWorks?: string;
  category?: string;
  features?: string[];
  icon?: string;
}

interface Props {
  services: Service[];
  theme?: 'light' | 'dark';
}

const { services, theme = 'light' } = Astro.props;
---

<section class={`services-showcase services-${theme}`}>
  <div class="container">
    {services.map((service, index) => {
      const isEven = index % 2 === 0;
      const alignment = isEven ? 'left' : 'right';
      
      return (
        <div class={`service-row service-row-${alignment}`}>
          <div class="service-content">
            {service.category && (
              <div class="service-category">{service.category}</div>
            )}
            <h3 class="service-title">{service.name}</h3>
            <p class="service-description">
              {service.howItWorks || service.description}
            </p>
            {service.features && service.features.length > 0 && (
              <ul class="service-features">
                {service.features.map((feature) => (
                  <li>{feature}</li>
                ))}
              </ul>
            )}
          </div>
          <div class="service-image">
            <div class="image-placeholder">
              <span class="placeholder-text">Service Image</span>
              <span class="placeholder-icon">📱</span>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .services-showcase {
    padding: 4rem 0;
  }
  
  .services-light {
    background: #ffffff;
    color: #212529;
  }
  
  .services-dark {
    background: #0a0a0a;
    color: #f5f5f5;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  
  .service-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    margin-bottom: 6rem;
  }
  
  .service-row:last-child {
    margin-bottom: 0;
  }
  
  @media (min-width: 768px) {
    .service-row {
      grid-template-columns: 1fr 1fr;
    }
    
    /* Left alignment: content on left, image on right */
    .service-row-left .service-content {
      order: 1;
    }
    
    .service-row-left .service-image {
      order: 2;
    }
    
    /* Right alignment: image on left, content on right */
    .service-row-right .service-content {
      order: 2;
    }
    
    .service-row-right .service-image {
      order: 1;
    }
  }
  
  .service-content {
    padding: 2rem 0;
  }
  
  .service-category {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.75rem;
  }
  
  .services-light .service-category {
    color: #2563eb;
  }
  
  .services-dark .service-category {
    color: #4a9eff;
  }
  
  .service-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .services-light .service-title {
    color: #212529;
  }
  
  .services-dark .service-title {
    color: #f5f5f5;
  }
  
  .service-description {
    font-size: 1.0625rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  
  .services-light .service-description {
    color: #495057;
  }
  
  .services-dark .service-description {
    color: #ccc;
  }
  
  .service-features {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .service-features li {
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.5;
  }
  
  .service-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    font-weight: 700;
    font-size: 1rem;
  }
  
  .services-light .service-features li {
    color: #495057;
  }
  
  .services-light .service-features li::before {
    color: #2563eb;
  }
  
  .services-dark .service-features li {
    color: #ccc;
  }
  
  .services-dark .service-features li::before {
    color: #4a9eff;
  }
  
  .service-image {
    position: relative;
    width: 100%;
    min-height: 400px;
    border-radius: 8px;
    overflow: hidden;
  }
  
  .image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 400px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2px dashed;
    border-radius: 8px;
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.05) 0%, rgba(37, 99, 235, 0.1) 100%);
    transition: all 0.3s ease;
  }
  
  .services-light .image-placeholder {
    border-color: #e8ecef;
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.05) 0%, rgba(37, 99, 235, 0.1) 100%);
  }
  
  .services-dark .image-placeholder {
    border-color: #333;
    background: linear-gradient(135deg, rgba(74, 158, 255, 0.05) 0%, rgba(74, 158, 255, 0.1) 100%);
  }
  
  .image-placeholder:hover {
    transform: scale(1.02);
  }
  
  .services-light .image-placeholder:hover {
    border-color: #2563eb;
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(37, 99, 235, 0.15) 100%);
  }
  
  .services-dark .image-placeholder:hover {
    border-color: #4a9eff;
    background: linear-gradient(135deg, rgba(74, 158, 255, 0.1) 0%, rgba(74, 158, 255, 0.15) 100%);
  }
  
  .placeholder-text {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
  }
  
  .services-light .placeholder-text {
    color: #6c757d;
  }
  
  .services-dark .placeholder-text {
    color: #999;
  }
  
  .placeholder-icon {
    font-size: 4rem;
    opacity: 0.5;
  }
  
  @media (max-width: 767px) {
    .service-row {
      margin-bottom: 4rem;
    }
    
    .service-image {
      min-height: 300px;
    }
    
    .image-placeholder {
      min-height: 300px;
    }
    
    .service-title {
      font-size: 1.75rem;
    }
  }
</style>
