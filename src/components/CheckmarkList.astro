---
interface Props {
  items: string[];
  columns?: 1 | 2 | 3;
  checkColor?: 'primary' | 'success';
}

const { items, columns = 1, checkColor = 'primary' } = Astro.props;
---

<ul class={`checkmark-list checkmark-list-${columns}col`} data-check-color={checkColor}>
  {items.map((item) => (
    <li class="checkmark-item">
      <span class="item-text">{item}</span>
    </li>
  ))}
</ul>

<style>
  .checkmark-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
  }
  
  .checkmark-list-1col {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  
  .checkmark-list-2col {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 0.8rem;
  }
  
  .checkmark-list-3col {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.8rem;
  }
  
  .checkmark-item {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #999;
    font-weight: 300;
    padding-left: 1rem;
  }
  
  .item-text {
    display: block;
  }
  
  @media (max-width: 768px) {
    .checkmark-list-2col,
    .checkmark-list-3col {
      grid-template-columns: 1fr;
    }
  }
</style>
