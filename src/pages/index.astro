<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>OurBond — Pages</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; background: #f3f4f6; margin: 0; padding: 2rem; }
    h1 { font-size: 1.125rem; font-weight: 700; color: #111; margin: 0 0 0.25rem; }
    .section-title { font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #9ca3af; margin: 0 0 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid #e5e7eb; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.625rem; }
    a.card { display: block; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.75rem 1rem; text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s; }
    a.card:hover { border-color: #2563eb; box-shadow: 0 0 0 3px #dbeafe; }
    a.card .label { font-size: 0.9375rem; font-weight: 600; color: #111; display: block; margin-bottom: 0.2rem; }
    a.card .url { font-size: 0.75rem; color: #6b7280; font-family: monospace; }
  </style>
</head>
<body>
  <h1>OurBond — Pages</h1>
  <p style="font-size:0.8125rem;color:#6b7280;margin:0 0 1.5rem;">Go Live — Merged Services &mdash; Track Me + Video Monitor Me</p>
  <div class="grid">
    <a class="card" href="/services/merged-students-individual" target="_blank">
      <span class="label">Students — Individual</span>
      <span class="url">/services/merged-students-individual</span>
    </a>
    <a class="card" href="/services/merged-students-individual-pricing" target="_blank">
      <span class="label">Students — Individual + Pricing</span>
      <span class="url">/services/merged-students-individual-pricing</span>
    </a>
    <a class="card" href="/services/merged-lone-workers-individual" target="_blank">
      <span class="label">Lone Workers — Individual</span>
      <span class="url">/services/merged-lone-workers-individual</span>
    </a>
    <a class="card" href="/services/merged-lone-workers-individual-pricing" target="_blank">
      <span class="label">Lone Workers — Individual + Pricing</span>
      <span class="url">/services/merged-lone-workers-individual-pricing</span>
    </a>
  </div>
</body>
</html>
