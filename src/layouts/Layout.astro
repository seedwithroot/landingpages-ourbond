---
import PageReview from '../components/PageReview.astro';
import { getAppStoreLink, getGooglePlayLink } from '../data/cta-links.js';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  googleTagId?: string;
}

const { 
  title, 
  description = "High-converting landing pages for PPC campaigns",
  ogImage = "/og-image.png",
  noIndex = false,
  googleTagId = "G-X3QS89GB4K" // Default GA4 tag for all pages
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.url)} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, Astro.url)} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Google Tag Manager / GA4 -->
    {googleTagId && (
      <>
        {googleTagId.startsWith('GTM-') ? (
          <!-- Google Tag Manager -->
          <script>
            (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
            new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','{googleTagId}');
          </script>
        ) : (
          <!-- Google tag (gtag.js) -->
          <>
            <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleTagId}`}></script>
            <script is:inline define:vars={{ googleTagId }}>
              window.dataLayer = window.dataLayer || [];
              function gtag(){dataLayer.push(arguments);}
              gtag('js', new Date());
              gtag('config', googleTagId);
            </script>
          </>
        )}
      </>
    )}
    
    <!-- Google Ads & UTM Parameter Tracking -->
    <script is:inline src="/scripts/track-params.js"></script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    {googleTagId && googleTagId.startsWith('GTM-') && (
      <noscript>
        <iframe src={`https://www.googletagmanager.com/ns.html?id=${googleTagId}`}
          height="0" width="0" style="display:none;visibility:hidden"></iframe>
      </noscript>
    )}
    
    <!-- Global Navigation -->
    <nav class="global-nav">
      <div class="container">
        <div class="nav-content">
          <a href="/" class="logo-link">
            <img src="https://www.ourbond.com/wp-content/themes/bond/src/images/bond-logo.svg" alt="OurBond" class="logo" />
          </a>
          <div class="nav-cta">
            <div class="nav-trial-text">
              <span class="nav-trial-dot"></span>
              Free 30-day trial
            </div>
            <div class="nav-buttons">
              <a href={getAppStoreLink('nav')} aria-label="Download on the App Store">
                <img src="/buttons/apple-light.png" alt="App Store" style="height: 32px; width: auto; display: block; filter: invert(1);" />
              </a>
              <a href={getGooglePlayLink('nav')} aria-label="Get it on Google Play">
                <img src="/buttons/google-light.png" alt="Google Play" style="height: 32px; width: auto; display: block; filter: invert(1);" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </nav>
    
    <slot />
    <PageReview />
  </body>
</html>

<style is:global>
  :root {
    --black: #39393B;
    --near-black: #ffffff;
    --panel: #f5f5f5;
    --border: #e0e0e0;
    --accent: #2563eb;
    --accent-dim: #1e40af;
    --accent-glow: rgba(37,99,235,0.12);
    --text: #39393B;
    --muted: #666666;
    --white: #ffffff;
    --color-primary: #2563eb;
    --color-primary-dark: #1e40af;
    --color-secondary: #0ea5e9;
    --color-accent: #2563eb;
    --color-text: #39393B;
    --color-text-light: #666666;
    --color-background: #ffffff;
    --color-gray-100: #f5f5f5;
    --color-gray-200: #e0e0e0;
    --color-gray-300: #cccccc;
    --color-success: #28a745;
    --color-error: #dc3545;
    --color-warning: #f59e0b;
    --font-sans: 'Barlow', sans-serif;
    --font-heading: 'Barlow Condensed', sans-serif;
    --transition-base: 0.25s ease;
    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.08);
    --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.1);
    --shadow-lg: 0 10px 30px rgba(0, 0, 0, 0.12);
    --shadow-xl: 0 20px 60px rgba(0, 0, 0, 0.15);
  }
  
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  
  html {
    font-family: var(--font-sans);
    scroll-behavior: smooth;
  }
  
  body {
    background: var(--white);
    color: var(--text);
    line-height: 1.6;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }
  
  /* Removed dark grid overlay for clean white background */
  
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    font-weight: 900;
    line-height: 1.1;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }
  
  h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    text-transform: uppercase;
  }
  
  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
  }
  
  h3 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
  }
  
  img {
    max-width: 100%;
    height: auto;
    display: block;
  }
  
  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--transition-base);
  }
  
  a:hover {
    color: var(--color-primary-dark);
  }
  
  button {
    font-family: inherit;
    cursor: pointer;
  }
  
  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  
  .container-narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  
  /* Global Navigation */
  .global-nav {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #e0e0e0;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
  }
  
  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.625rem 0;
  }

  .nav-cta {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-trial-text {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 1.0625rem;
    font-weight: 800;
    color: #2563eb;
    margin: 0;
    line-height: 1.2;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  .nav-trial-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.6);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%   { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.55); }
    70%  { box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
    100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
  }

  .nav-buttons {
    display: flex;
    gap: 0.625rem;
    align-items: center;
  }

  .nav-app-btn {
    height: 32px;
    width: auto;
    display: block;
    filter: invert(1);
    transition: opacity 0.15s;
  }

  .nav-app-btn:hover {
    opacity: 0.8;
  }
  
  .logo-link {
    display: flex;
    align-items: center;
  }
  
  .logo {
    height: 32px;
    width: auto;
  }
  
  .nav-phone {
    font-family: var(--font-heading);
    color: #0a0a0a;
    font-weight: 700;
    font-size: 1.125rem;
    transition: color var(--transition-base);
    letter-spacing: -0.01em;
  }
  
  .nav-phone:hover {
    color: var(--color-primary);
  }
  
  /* CTA Button Styles */
  .cta-primary {
    font-family: var(--font-heading);
    background: var(--accent);
    color: var(--white);
    padding: 0.85rem 2rem;
    font-size: 0.9rem;
    font-weight: 700;
    border: none;
    border-radius: 0;
    box-shadow: none;
    transition: background 0.2s, transform 0.15s;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }
  
  .cta-primary:hover {
    background: var(--accent-dim);
    transform: translateY(-1px);
  }
  
  .cta-primary:active {
    transform: translateY(0);
  }
  
  .cta-secondary {
    font-family: var(--font-heading);
    background: transparent;
    color: var(--accent);
    padding: 0.875rem 2rem;
    font-size: 0.9rem;
    font-weight: 700;
    border: 2px solid var(--accent);
    border-radius: 0;
    transition: background var(--transition-base), color var(--transition-base);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: inline-block;
    text-decoration: none;
  }
  
  .cta-secondary:hover {
    background: var(--accent);
    color: var(--white);
  }
  
  .cta-large {
    font-family: var(--font-heading);
    background: var(--accent);
    color: var(--white);
    padding: 1rem 2.5rem;
    font-size: 1rem;
    font-weight: 700;
    border: none;
    border-radius: 0;
    box-shadow: none;
    transition: background 0.2s, transform 0.15s;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }
  
  .cta-large:hover {
    background: var(--accent-dim);
    transform: translateY(-1px);
  }
  
  /* Section Spacing */
  section {
    padding: 2.5rem 0;
    position: relative;
  }
  
  @media (min-width: 768px) {
    section {
      padding: 4rem 0;
    }
  }
  
  /* Responsive */
  @media (max-width: 768px) {
    .container,
    .container-narrow {
      padding: 0 1rem;
    }
    
    .logo {
      height: 28px;
    }
    
    .nav-phone span {
      font-size: 1rem;
    }
    
    .cta-primary,
    .cta-secondary {
      width: 100%;
      padding: 0.875rem 1.5rem;
      font-size: 0.9375rem;
    }
    
    .cta-large {
      padding: 1rem 2rem;
      font-size: 1rem;
    }
    
    section {
      padding: 2rem 0;
    }
  }
  
  /* Tighter Spacing Utilities */
  h1, h2, h3 {
    margin-bottom: 1rem;
  }
  
  h4, h5, h6 {
    margin-bottom: 0.75rem;
  }
  
  p {
    margin-bottom: 1rem;
  }
  
  p:last-child {
    margin-bottom: 0;
  }

</style>
