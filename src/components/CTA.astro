---
interface Props {
  headline?: string;
  ctaText: string;
  ctaUrl?: string;
  variant?: 'banner' | 'centered' | 'split';
  urgency?: string;
  subtext?: string;
}

const { 
  headline = "Ready to Get Started?",
  ctaText,
  ctaUrl = '#',
  variant = 'banner',
  urgency,
  subtext
} = Astro.props;
---

<section class={`cta-section cta-${variant}`}>
  <div class="container">
    <div class="cta-content">
      <div class="cta-text">
        <h2 class="cta-headline">{headline}</h2>
        {subtext && <p class="cta-subtext">{subtext}</p>}
        {urgency && <p class="cta-urgency">⏰ {urgency}</p>}
      </div>
      <div class="cta-action">
        <a href={ctaUrl} class="cta-large">{ctaText}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 5rem 0;
  }
  
  .cta-banner {
    background: var(--accent);
    color: var(--white);
  }
  
  .cta-centered {
    background: var(--panel);
    text-align: center;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  
  .cta-split {
    background: var(--white);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  
  .cta-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }
  
  @media (min-width: 768px) {
    .cta-split .cta-content {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
  
  .cta-banner .cta-headline {
    color: var(--white);
  }
  
  .cta-headline {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 900;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
    line-height: 1;
  }
  
  .cta-centered .cta-headline,
  .cta-split .cta-headline {
    color: var(--text);
  }
  
  .cta-subtext {
    font-size: 1.125rem;
    opacity: 0.85;
    margin-bottom: 1rem;
    font-weight: 400;
  }
  
  .cta-banner .cta-subtext {
    color: rgba(255,255,255,0.9);
  }
  
  .cta-urgency {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 0;
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  
  .cta-banner .cta-large {
    background: var(--white);
    color: var(--accent);
  }
  
  .cta-banner .cta-large:hover {
    background: var(--panel);
    transform: translateY(-1px);
  }
  
  @media (max-width: 768px) {
    .cta-section {
      padding: 3rem 0;
    }
    
    .cta-content {
      gap: 1.5rem;
    }
    
    .cta-headline {
      font-size: 1.75rem;
    }
    
    .cta-action {
      width: 100%;
    }
    
    .cta-large {
      width: 100%;
    }
  }
</style>
