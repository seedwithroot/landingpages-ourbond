---
/**
 * PricingSection — universal pricing module with monthly/annual toggle.
 *
 * Usage:
 *   import PricingSection from '../components/PricingSection.astro';
 *   <PricingSection plans={plans} />
 *
 * Each plan object:
 *   id:           string  — unique key used for scoping (e.g. "ind", "fam")
 *   name:         string  — display name
 *   subtitle?:    string  — shown below name (e.g. "Up to 5 members")
 *   featured?:    boolean — shows "Most popular" banner + blue border
 *   ctaText?:     string  — CTA button label (default: "Try 30 days free")
 *   ctaHref?:     string  — CTA button href (default: "#")
 *   featuresLabel?: string — label above feature list
 *   features:     string[] — feature bullet lines
 *   monthly:      { was?: string; price: string; unit?: string }
 *   annual:       { was?: string; price: string; unit?: string; billed?: string }
 */

export interface PricingPlan {
  id: string;
  name: string;
  subtitle?: string;
  featured?: boolean;
  ctaText?: string;
  ctaHref?: string;
  ctaHrefMonthly?: string;
  ctaHrefAnnual?: string;
  featuresLabel?: string;
  features: string[];
  monthly: {
    was?: string;
    price: string;
    unit?: string;
  };
  annual: {
    was?: string;
    price: string;
    unit?: string;
    billed?: string;
  };
}

export interface Props {
  /** Eyebrow label above headline */
  eyebrow?: string;
  /** Main heading */
  headline?: string;
  /** Subheading below headline */
  subheadline?: string;
  /** Badge text on the annual toggle button */
  saveBadgeText?: string;
  /** Pricing plans */
  plans: PricingPlan[];
  /** Background color */
  bg?: string;
}

const {
  eyebrow = 'Pricing',
  headline = 'Simple, transparent pricing.',
  subheadline = 'Cancel any time. No contracts.',
  saveBadgeText = 'Save up to 10%',
  plans,
  bg = '#f5f4f1',
} = Astro.props;

// Unique ID scopes this instance so multiple sections can coexist on a page.
const uid = `ps-${Math.random().toString(36).slice(2, 8)}`;
---

<section
  id="pricing"
  data-pricing-uid={uid}
  style={`background: ${bg}; padding: 5rem 0; position: relative;`}
>
  <div style="max-width: 920px; margin: 0 auto; padding: 0 2rem; text-align: center;">
    {eyebrow && (
      <p style="font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #2563eb; margin: 0 0 0.75rem;">
        {eyebrow}
      </p>
    )}
    {headline && (
      <h2 style="font-size: clamp(2rem, 3.5vw, 2.75rem); font-weight: 800; color: #111; line-height: 1.15; margin: 0 0 0.5rem;">
        {headline}
      </h2>
    )}
    {subheadline && (
      <p style="font-size: 1.0625rem; color: #555; margin: 0 0 2.5rem;">{subheadline}</p>
    )}

    <!-- Toggle -->
    <div style="display: inline-flex; background: #fff; border-radius: 999px; padding: 0.25rem; border: 1px solid #e5e5e5; margin-bottom: 3rem; gap: 0;">
      <button
        data-period-btn="monthly"
        style="font-size: 0.9375rem; font-weight: 600; padding: 0.5rem 1.5rem; border-radius: 999px; border: none; cursor: pointer; background: #111; color: #fff; transition: background 0.15s, color 0.15s;"
      >
        Monthly
      </button>
      <button
        data-period-btn="annual"
        style="font-size: 0.9375rem; font-weight: 600; padding: 0.5rem 1.5rem; border-radius: 999px; border: none; cursor: pointer; background: transparent; color: #555; display: flex; align-items: center; gap: 0.5rem; transition: background 0.15s, color 0.15s;"
      >
        Annually
        {saveBadgeText && (
          <span style="font-size: 0.75rem; font-weight: 700; background: #dcfce7; color: #166534; padding: 0.15rem 0.5rem; border-radius: 4px;">
            {saveBadgeText}
          </span>
        )}
      </button>
    </div>

    <!-- Plan cards -->
    <div style={`display: grid; grid-template-columns: repeat(${plans.length}, 1fr); gap: 1.5rem; text-align: left; align-items: stretch;`}>
      {plans.map(plan => (
        <div style={`background: #fff; border-radius: 20px; padding: 2rem; border: ${plan.featured ? '2px solid #2563eb' : '1px solid #e5e5e5'}; position: relative; overflow: hidden; display: flex; flex-direction: column;`}>
          {plan.featured && (
            <div style="position: absolute; top: 0; left: 0; right: 0; background: #2563eb; text-align: center; padding: 0.4rem; font-size: 0.8125rem; font-weight: 700; color: #fff; letter-spacing: 0.04em;">
              Most popular
            </div>
          )}
          <div style={`display: flex; flex-direction: column; flex: 1; ${plan.featured ? 'margin-top: 1.5rem;' : ''}`}>
            <p style="font-size: 1.375rem; font-weight: 800; color: #111; margin: 0 0 0.375rem;">{plan.name}</p>
            {plan.subtitle && (
              <p style="font-size: 0.9rem; color: #555; margin: 0 0 1rem;">{plan.subtitle}</p>
            )}

            <!-- Monthly price block -->
            <div data-price-monthly style="margin-bottom: 1.5rem;">
              {plan.monthly.was && (
                <p style="font-size: 0.8125rem; color: #aaa; text-decoration: line-through; margin: 0 0 0.125rem;">{plan.monthly.was}</p>
              )}
              <p style="font-size: 2.25rem; font-weight: 800; color: #111; margin: 0; line-height: 1;">
                {plan.monthly.price}
                <span style="font-size: 1rem; font-weight: 500; color: #555;">{plan.monthly.unit ?? '/mo'}</span>
              </p>
            </div>

            <!-- Annual price block -->
            <div data-price-annual style="display: none; margin-bottom: 1.5rem;">
              {plan.annual.was && (
                <p style="font-size: 0.8125rem; color: #aaa; text-decoration: line-through; margin: 0 0 0.125rem;">{plan.annual.was}</p>
              )}
              <p style="font-size: 2.25rem; font-weight: 800; color: #111; margin: 0; line-height: 1;">
                {plan.annual.price}
                <span style="font-size: 1rem; font-weight: 500; color: #555;">{plan.annual.unit ?? '/mo'}</span>
              </p>
              {plan.annual.billed && (
                <p style="font-size: 0.8125rem; color: #166534; font-weight: 600; margin: 0.25rem 0 0;">{plan.annual.billed}</p>
              )}
            </div>

            {plan.featuresLabel && (
              <p style="font-size: 0.875rem; font-weight: 700; color: #111; margin: 0 0 0.75rem;">{plan.featuresLabel}</p>
            )}
            <ul style="list-style: none; padding: 0; margin: 0 0 1.75rem; display: flex; flex-direction: column; gap: 0.6rem;">
              {plan.features.map(f => (
                <li style="font-size: 0.9375rem; color: #333; display: flex; gap: 0.6rem; align-items: flex-start;">
                  <span style="color: #2563eb; font-weight: 700; flex-shrink: 0;">&#10003;</span>
                  {f}
                </li>
              ))}
            </ul>

            <a
              data-cta-link
              data-href-monthly={plan.ctaHrefMonthly ?? plan.ctaHref ?? '#'}
              data-href-annual={plan.ctaHrefAnnual ?? plan.ctaHref ?? '#'}
              href={plan.ctaHrefMonthly ?? plan.ctaHref ?? '#'}
              style={`display: block; background: ${plan.featured ? '#2563eb' : '#111'}; color: #fff; text-align: center; font-size: 1rem; font-weight: 700; padding: 0.875rem 1.5rem; border-radius: 10px; text-decoration: none; margin-top: auto;`}
            >
              {plan.ctaText ?? 'Try 30 days free'}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline define:vars={{ uid }}>
  (function () {
    var section = document.querySelector('[data-pricing-uid="' + uid + '"]');
    if (!section) return;

    var mBtn = section.querySelector('[data-period-btn="monthly"]');
    var aBtn = section.querySelector('[data-period-btn="annual"]');

    function applyPeriod(isAnnual) {
      section.querySelectorAll('[data-price-monthly]').forEach(function (el) {
        el.style.display = isAnnual ? 'none' : 'block';
      });
      section.querySelectorAll('[data-price-annual]').forEach(function (el) {
        el.style.display = isAnnual ? 'block' : 'none';
      });
      section.querySelectorAll('[data-cta-link]').forEach(function (link) {
        var monthlyHref = link.getAttribute('data-href-monthly');
        var annualHref = link.getAttribute('data-href-annual');
        link.setAttribute('href', isAnnual ? annualHref : monthlyHref);
      });
      mBtn.style.background = isAnnual ? 'transparent' : '#111';
      mBtn.style.color = isAnnual ? '#555' : '#fff';
      aBtn.style.background = isAnnual ? '#111' : 'transparent';
      aBtn.style.color = isAnnual ? '#fff' : '#555';
    }

    mBtn.addEventListener('click', function () { applyPeriod(false); });
    aBtn.addEventListener('click', function () { applyPeriod(true); });
  })();
</script>
