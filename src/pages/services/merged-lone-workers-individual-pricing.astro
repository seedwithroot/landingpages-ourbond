---
import Layout from '../../layouts/Layout.astro';
import reviewsData from '../../data/reviews-lone-workers-individual.js';
import PricingSection from '../../components/PricingSection.astro';
import { getPricingPlans } from '../../data/pricing.js';
import { getAppStoreLink, getGooglePlayLink } from '../../data/cta-links.js';

const pricingPlans = getPricingPlans('lone-workers');

const page = {

  meta: {
    title: "Lone Worker Safety — You're Never Truly Alone | Bond",
    description: "A trained security agent is ready before every shift — so your trusted contact always knows where you are and help is one tap away. Free.",
  },

  hero: {
    label: "A — Hero",
    headline: "If something went wrong out there, Bond would already be on it.",
    subheadline: "A trained security agent is ready before every shift — watching your location, ready to act, one tap from stepping in on video. Your supervisor or safety contact can follow along.",
    bullets: [
      "A trained security agent watching over your location and route, available on video in seconds",
      "One tap to your agent if anything feels wrong — Bond is already watching",
      "Auto-escalation if you stop responding or go off-route",
      "Your trusted contact follows your live location throughout the shift",
    ],
    trustLine: "Trusted by lone workers across trades, security, utilities, and field services",
    image: "https://www.ourbond.com/wp-content/uploads/slider114/group-487bs_standarts_image.png",
    imageAlt: "Bond app — Track Me On The Go",
    showAppButtons: true
  },

  featureGrid: {
    label: "B — Feature Cards",
    headline: "Bond is more than just {focusedService}.",
    subheadline: "Live tracking is just the start. Bond gives your trusted contact full shift visibility — every location, every check-in — and a live agent ready when it matters.",
    video: "https://www.ourbond.com/wp-content/uploads/slider112/bond_website_loop_v5_comp_x3.mp4",
    showAppButtons: true,
    cards: [
      {
        icon: "user-check",
        title: "Agent ready before you go out",
        body: "Before your shift begins, a trained security agent connects with access to your location, role, and route. Bond is watching before you even leave.",
      },
      {
        icon: "bell",
        title: "Automatic end-of-shift alert",
        body: "Bond automatically notifies your trusted contact when your shift is complete and you've left site safely. No check-in phone call. No unanswered texts.",
      },
      {
        icon: "map",
        title: "Your contact follows every shift",
        body: "Bond shares your live location with a trusted colleague, supervisor, or safety officer from the moment you leave — every location, every stop, every stretch alone.",
      },
    ],
  },

  featureSections: [
    {
      id: "feature-solo-shift",
      label: "C — Focused Service",
      position: "after-reviews",
      layout: "copy-left",
      eyebrow: "Lone Worker Safety",
      headline: "Your agent is watching.\nEvery shift. Every site.",
      body: "A trained security agent is ready before every shift — with access to your location, role, and route. Bond watches in real time from start to finish. If you stop responding, Bond acts. Your trusted contact can follow along, and the agent is available on video in seconds.",
      bullets: [
        "Agent ready before every shift begins, with access to your location and route",
        "Works outdoors, in low-signal areas, and across large job sites",
        "Auto-escalation if you go off-route or stop responding",
        "Your trusted contact follows your live location throughout the shift",
      ],
      showAppButtons: true,
      media: {
        type: "video-clickplay",
        poster: "https://www.ourbond.com/wp-content/themes/bond/src/images/how-bond-works/track-my-walk-video-still.jpg",
        src: "https://www.ourbond.com/wp-content/uploads/2019/11/track_my_walk.mp4",
        alt: "Track Me On The Go — click to play",
      },
    },
    {
      id: "feature-check-in",
      label: "D — Safe Return",
      position: "after-grid",
      layout: "copy-right",
      eyebrow: "End-of-shift safe return",
      headline: "Your contact will know\nyou finished safe.\nBefore they start calling.",
      body: "Bond monitors your shift from start to finish and automatically notifies your trusted contact when you leave site safely. If Bond doesn't detect your safe return, a live agent steps in immediately.",
      bullets: [
        "Shift monitoring from start to safe return",
        "Trusted contact notified automatically at end of shift",
        "Auto-escalation if no safe return is detected",
        "First responders orchestrated if needed",
      ],
      showAppButtons: true,
      media: {
        type: "video-autoplay",
        src: "https://www.ourbond.com/wp-content/themes/bond/src/gifs/track-me-on-the-go.mp4",
        alt: "Track Me On The Go",
      },
    },
    {
      id: "feature-vmm",
      label: "E — Video Monitor Me",
      position: "after-grid",
      layout: "copy-left",
      eyebrow: "Video Monitor Me",
      headline: "If something goes wrong on site,\none tap — a live agent\nis right there with you.",
      body: "Video Monitor Me puts a trained Bond security agent on your screen via live video the moment you tap — watching you, your surroundings, and the situation in real time. They stay on the line until you're safe or emergency services are on the way.",
      bullets: [
        "Live video, audio, or text — connect however feels right",
        "Agent monitors your surroundings and situation in real time",
        "Agent appears in seconds — no hold time, no call queue",
        "First responders orchestrated if needed",
      ],
      showAppButtons: true,
      media: {
        type: "video-clickplay",
        poster: "https://www.ourbond.com/wp-content/themes/bond/src/images/how-bond-works/video-monitor-me-video-still.jpg",
        src: "https://www.ourbond.com/wp-content/uploads/2019/11/video_monitor_me.mp4",
        alt: "Video Monitor Me",
      },
    },
  ],

  hook: {
    label: "F — Hook CTA",
    headline: "Most lone worker incidents happen\nin the window between\nthe last check-in and the next.",
    body: "Bond closes that window — live location, a live agent on standby, and an automatic safe-return alert. Set it up once. Run it every shift.",
    showAppButtons: true,
  },

  socialProof: {
    label: "G — Social Proof",
    eyebrow: "Trusted by lone workers across every industry",
    headline: "Get the App\nLoved by\nworkers\neverywhere.",
    rating: "4.8 out of 5",
    showAppButtons: true,
    reviewCount: 2,
  },

};

const reviews = reviewsData.reviews.slice(0, 5);
const focusedService = page.featureSections.find(s => s.position === 'after-reviews')?.eyebrow ?? 'location tracking';
const featureGridHeadline = page.featureGrid.headline.replace('{focusedService}', focusedService);
---

<Layout title={page.meta.title} description={page.meta.description}>
  <div style="background: #f5f4f1; border-bottom: 1px solid #e5e5e5; padding: 0.75rem 0; position: relative;">
    <div class="container" style="display: flex; justify-content: center;">
      <picture>
        <source media="(max-width: 768px)" srcset="/images/partners_mobile_oneline.png" />
        <source media="(min-width: 769px)" srcset="https://www.ourbond.com/wp-content/uploads/slider113/partners_fully.png" />
        <img
          src="https://www.ourbond.com/wp-content/uploads/slider113/partners_fully.png"
          alt="As seen on NBC, CBS, FOX, BBC, Yahoo Finance, Forbes, AP, iHeart Radio, Daily Mail, The Times, New York Post, Sky News"
          style="max-width: 1100px; width: 100%; height: auto; opacity: 0.65;"
        />
      </picture>
    </div>
  </div>
  <section id="hero" style="background: #faf9f6; padding: 5rem 0 3rem; position: relative;">
    <div class="hero-grid">
      <div>
        <h1 style="font-size: 3.25rem; font-weight: 800; line-height: 1.15; color: #111; margin: 0 0 1.25rem;">
          {page.hero.headline.split('\n').map((line, i) => (
            <>{line}{i < page.hero.headline.split('\n').length - 1 && <br />}</>
          ))}
        </h1>
        <p style="font-size: 1.1875rem; color: #444; line-height: 1.6; margin: 0 0 1.5rem; max-width: 480px;">
          {page.hero.subheadline}
        </p>
        {page.hero.bullets && page.hero.bullets.length > 0 && (
          <ul style="margin: 0 0 2rem; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.75rem;">
            {page.hero.bullets.map(b => (
              <li style="display: flex; align-items: flex-start; gap: 0.625rem; font-size: 0.975rem; color: #222; line-height: 1.45; max-width: 480px;">
                <span style="display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;width:24px;height:24px;border-radius:50%;background:#7870c4;background-image:url(&quot;data:image/svg+xml;charset=utf-8,%3Csvg width='12' height='10' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill-rule='evenodd' clip-rule='evenodd' d='M.5 6.062l1.772-1.906L4.347 6.12 10.052.6 11.5 2.528 4.297 9.4.5 6.062z' fill='%23fff'/%3E%3C/svg%3E&quot;);background-repeat:no-repeat;background-position:50%;"></span>
                {b}
              </li>
            ))}
          </ul>
        )}
        {page.hero.showAppButtons && (
          <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;">
            <a href={getAppStoreLink('hero')}>
              <img src="/buttons/apple-light.png" alt="Download on the App Store" style="height: 48px; width: auto; filter: invert(1);" />
            </a>
            <a href={getGooglePlayLink('hero')}>
              <img src="/buttons/google-light.png" alt="Get it on Google Play" style="height: 48px; width: auto; filter: invert(1);" />
            </a>
          </div>
        )}
        {page.hero.trustLine && (
          <p style="margin-top: 1rem; font-size: 0.9rem; color: #888;">{page.hero.trustLine}</p>
        )}
      </div>
      <div class="hero-phone" style="display: flex; justify-content: center;">
        <img src={page.hero.image} alt={page.hero.imageAlt} style="max-width: 420px; width: 100%; border-radius: 16px;" />
      </div>
    </div>
  </section>
  <section id="review-strip" style="background: #fff; padding: 2.5rem 0; border-top: 1px solid #eee; border-bottom: 1px solid #eee; position: relative;">
    <div style="display: flex; gap: 1.5rem; padding: 0 2rem; flex-wrap: wrap; justify-content: center; max-width: 1100px; margin: 0 auto;">
      {reviews.slice(0, 4).map(r => (
        <div style="background: #faf9f6; border-radius: 12px; padding: 1.25rem 1.5rem; max-width: 300px; flex: 1; min-width: 240px;">
          <div style="color: #f59e0b; font-size: 0.875rem; margin-bottom: 0.5rem;">{"★".repeat(r.rating ?? 5)}</div>
          <p style="font-size: 0.9375rem; color: #333; line-height: 1.5; margin: 0 0 0.75rem;">"{r.text.slice(0, 120)}…"</p>
        </div>
      ))}
    </div>
  </section>
  {page.featureSections.filter(s => s.position === 'after-reviews').map(s => (
    <section id={s.id} style={`background: ${s.bg}; padding: 5rem 0; position: relative;`}>
      <div class={`feature-row${s.layout === 'copy-right' ? ' feature-row--media-first' : ''}`}>
        {s.layout === 'copy-left' && (
          <div class="feature-copy">
            <p class="feature-eyebrow">{s.eyebrow}</p>
            <h2 class="feature-headline">{s.headline}</h2>
            <p class="feature-body">{s.body}</p>
            <ul class="feature-list">{s.bullets.map(b => <li>{b}</li>)}</ul>
            {s.showAppButtons && (
              <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem;">
                <a href={getAppStoreLink(s.id)}>
                  <img src="/buttons/apple-light.png" alt="Download on the App Store" style="height: 44px; width: auto; filter: invert(1);" />
                </a>
                <a href={getGooglePlayLink(s.id)}>
                  <img src="/buttons/google-light.png" alt="Get it on Google Play" style="height: 44px; width: auto; filter: invert(1);" />
                </a>
              </div>
            )}
          </div>
        )}
        <div class="feature-media">
          {s.media.type === 'video-clickplay' ? (
            <div class="video-player" data-video={s.media.src}>
              <img src={s.media.poster} alt={s.media.alt} class="video-player__poster feature-img" />
              <button class="video-player__btn" aria-label="Play video">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><polygon points="5,3 19,12 5,21"/></svg>
              </button>
              <video class="video-player__video feature-img" preload="none" controls style="display:none;"></video>
            </div>
          ) : s.media.type === 'video-autoplay' ? (
            <video src={s.media.src} class="feature-img" autoplay muted loop playsinline></video>
          ) : (
            <img src={s.media.src} alt={s.media.alt} class="feature-img" />
          )}
        </div>
        {s.layout === 'copy-right' && (
          <div class="feature-copy">
            <p class="feature-eyebrow">{s.eyebrow}</p>
            <h2 class="feature-headline">{s.headline}</h2>
            <p class="feature-body">{s.body}</p>
            <ul class="feature-list">{s.bullets.map(b => <li>{b}</li>)}</ul>
            {s.showAppButtons && (
              <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem;">
                <a href={getAppStoreLink(s.id)}>
                  <img src="/buttons/apple-light.png" alt="Download on the App Store" style="height: 44px; width: auto; filter: invert(1);" />
                </a>
                <a href={getGooglePlayLink(s.id)}>
                  <img src="/buttons/google-light.png" alt="Get it on Google Play" style="height: 44px; width: auto; filter: invert(1);" />
                </a>
              </div>
            )}
          </div>
        )}
      </div>
    </section>
  ))}
  <section id="features" style="background: #faf9f6; padding: 5rem 0; position: relative;">
    <div class="container" style="max-width: 1100px; margin: 0 auto; padding: 0 2rem;">
      <h2 style="font-size: 2.5rem; font-weight: 800; color: #111; text-align: center; margin: 0 0 0.75rem;">{featureGridHeadline}</h2>
      <p style="text-align: center; color: #555; font-size: 1.125rem; margin: 0 0 1.75rem; max-width: 600px; margin-left: auto; margin-right: auto;">{page.featureGrid.subheadline}</p>
      {page.featureGrid.showAppButtons && (
        <div style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem;">
          <a href={getAppStoreLink('features')}>
            <img src="/buttons/apple-light.png" alt="Download on the App Store" style="height: 48px; width: auto; filter: invert(1);" />
          </a>
          <a href={getGooglePlayLink('features')}>
            <img src="/buttons/google-light.png" alt="Get it on Google Play" style="height: 48px; width: auto; filter: invert(1);" />
          </a>
        </div>
      )}
      {page.featureGrid.video && (
        <div style="margin-bottom: 3.5rem; border-radius: 20px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.1);">
          <video src={page.featureGrid.video} autoplay muted loop playsinline style="width: 100%; display: block;"></video>
        </div>
      )}
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
        {page.featureGrid.cards.map(card => (
          <div style="background: #fff; border-radius: 16px; padding: 2rem; border: 1px solid #eee;">
            <h3 style="font-size: 1.3125rem; font-weight: 700; color: #111; margin: 0 0 0.6rem;">{card.title}</h3>
            <p style="font-size: 1rem; color: #555; line-height: 1.6; margin: 0;">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <PricingSection plans={pricingPlans} />
  {page.featureSections.filter(s => s.position === 'after-grid').map(s => (
    <section id={s.id} style={`background: ${s.bg}; padding: 5rem 0; position: relative;`}>
      <div class={`feature-row${s.layout === 'copy-right' ? ' feature-row--media-first' : ''}`}>
        {s.layout === 'copy-left' && (
          <div class="feature-copy">
            <p class="feature-eyebrow">{s.eyebrow}</p>
            <h2 class="feature-headline">{s.headline}</h2>
            <p class="feature-body">{s.body}</p>
            <ul class="feature-list">{s.bullets.map(b => <li>{b}</li>)}</ul>
            {s.showAppButtons && (
              <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem;">
                <a href={getAppStoreLink(s.id)}>
                  <img src="/buttons/apple-light.png" alt="Download on the App Store" style="height: 44px; width: auto; filter: invert(1);" />
                </a>
                <a href={getGooglePlayLink(s.id)}>
                  <img src="/buttons/google-light.png" alt="Get it on Google Play" style="height: 44px; width: auto; filter: invert(1);" />
                </a>
              </div>
            )}
          </div>
        )}
        <div class="feature-media">
          {s.media.type === 'video-clickplay' ? (
            <div class="video-player" data-video={s.media.src}>
              <img src={s.media.poster} alt={s.media.alt} class="video-player__poster feature-img" />
              <button class="video-player__btn" aria-label="Play video">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><polygon points="5,3 19,12 5,21"/></svg>
              </button>
              <video class="video-player__video feature-img" preload="none" controls style="display:none;"></video>
            </div>
          ) : s.media.type === 'video-autoplay' ? (
            <video src={s.media.src} class="feature-img" autoplay muted loop playsinline></video>
          ) : (
            <img src={s.media.src} alt={s.media.alt} class="feature-img" />
          )}
        </div>
        {s.layout === 'copy-right' && (
          <div class="feature-copy">
            <p class="feature-eyebrow">{s.eyebrow}</p>
            <h2 class="feature-headline">{s.headline}</h2>
            <p class="feature-body">{s.body}</p>
            <ul class="feature-list">{s.bullets.map(b => <li>{b}</li>)}</ul>
            {s.showAppButtons && (
              <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem;">
                <a href={getAppStoreLink(s.id)}>
                  <img src="/buttons/apple-light.png" alt="Download on the App Store" style="height: 44px; width: auto; filter: invert(1);" />
                </a>
                <a href={getGooglePlayLink(s.id)}>
                  <img src="/buttons/google-light.png" alt="Get it on Google Play" style="height: 44px; width: auto; filter: invert(1);" />
                </a>
              </div>
            )}
          </div>
        )}
      </div>
    </section>
  ))}
  <section id="hook" style="background: #111; padding: 5rem 0; position: relative;">
    <div class="container" style="max-width: 760px; margin: 0 auto; padding: 0 2rem; text-align: center;">
      <h2 style="font-size: 2.75rem; font-weight: 800; color: #fff; line-height: 1.2; margin: 0 0 1.25rem;">
        {page.hook.headline.split('\n').map((line, i) => (
          <>{line}{i < page.hook.headline.split('\n').length - 1 && <br />}</>
        ))}
      </h2>
      <p style="font-size: 1.1875rem; color: #aaa; line-height: 1.65; margin: 0 0 2.5rem;">{page.hook.body}</p>
      {page.hook.showAppButtons && (
        <div style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;">
          <a href={getAppStoreLink('hook')}>
            <img src="/buttons/apple-light.png" alt="Download on the App Store" style="height: 52px; width: auto;" />
          </a>
          <a href={getGooglePlayLink('hook')}>
            <img src="/buttons/google-light.png" alt="Get it on Google Play" style="height: 52px; width: auto;" />
          </a>
        </div>
      )}
    </div>
  </section>
  <section id="social-proof" style="background: #faf9f6; padding: 5rem 0; position: relative;">
    <div class="proof-grid">
      <div>
        <p style="font-size: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #888; margin: 0 0 1rem;">{page.socialProof.eyebrow}</p>
        <h2 style="font-size: 3rem; font-weight: 800; color: #111; margin: 0 0 1rem; line-height: 1.1;">
          {page.socialProof.headline.split('\n').map((line, i) => (
            <>{line}{i < page.socialProof.headline.split('\n').length - 1 && <br />}</>
          ))}
        </h2>
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem;">
          <span style="color: #f59e0b; font-size: 1.25rem;">★★★★★</span>
          <span style="font-size: 1rem; color: #333; font-weight: 600;">{page.socialProof.rating}</span>
        </div>
        {page.socialProof.showAppButtons && (
          <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href={getAppStoreLink('social-proof')}>
              <img src="/buttons/apple-light.png" alt="Download on the App Store" style="height: 48px; width: auto; filter: invert(1);" />
            </a>
            <a href={getGooglePlayLink('social-proof')}>
              <img src="/buttons/google-light.png" alt="Get it on Google Play" style="height: 48px; width: auto; filter: invert(1);" />
            </a>
          </div>
        )}
      </div>
      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        {reviews.slice(0, page.socialProof.reviewCount).map(r => (
          <div style="background: #fff; border-radius: 12px; padding: 1.5rem; border: 1px solid #eee;">
            <div style="color: #f59e0b; margin-bottom: 0.5rem;">{"★".repeat(r.rating ?? 5)}</div>
            <p style="font-size: 1rem; color: #333; line-height: 1.55; margin: 0 0 0.75rem;">"{r.text.slice(0, 160)}…"</p>
          </div>
        ))}
      </div>
    </div>
  </section>


</Layout>

<style>
  :global(body) { background: #faf9f6; color: #111; }
  .hero-grid, .proof-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
  .feature-row { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
  .feature-eyebrow { font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #2563eb; margin: 0 0 0.75rem; }
  .feature-headline { font-size: clamp(1.875rem, 3vw, 2.625rem); font-weight: 800; color: #111; line-height: 1.15; margin: 0 0 1.125rem; }
  .feature-body { font-size: 1.0625rem; color: #555; line-height: 1.65; margin: 0 0 1.75rem; max-width: 500px; }
  .feature-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; }
  .feature-list li { font-size: 1rem; color: #333; display: flex; align-items: center; }
  .feature-list li::before { background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg width='12' height='10' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill-rule='evenodd' clip-rule='evenodd' d='M.5 6.062l1.772-1.906L4.347 6.12 10.052.6 11.5 2.528 4.297 9.4.5 6.062z' fill='%23fff'/%3E%3C/svg%3E"); background-position: 50%; background-repeat: no-repeat; background-color: #7870c4; content: ""; display: inline-block; flex-shrink: 0; width: 24px; height: 24px; border-radius: 50%; margin-right: 12px; }
  .feature-media { display: flex; justify-content: center; align-items: center; }
  .feature-img { width: 100%; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.1); }
  @media (max-width: 768px) {
    .hero-grid, .proof-grid, .feature-row { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-grid h1 { font-size: 2.25rem !important; }
    #hook h2 { font-size: 2rem !important; }
    .hero-phone { display: none; }
  }
  .video-player { position: relative; display: inline-block; width: 100%; cursor: pointer; }
  .video-player__poster { display: block; }
  .video-player__btn { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 64px; height: 64px; border-radius: 50%; background: rgba(0,0,0,0.6); border: 2px solid rgba(255,255,255,0.8); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s, transform 0.2s; backdrop-filter: blur(4px); }
  .video-player__btn:hover { background: rgba(37, 99, 235, 0.85); transform: translate(-50%, -50%) scale(1.08); }
  .video-player__video { display: none; }
</style>

<script>
  document.querySelectorAll('.video-player').forEach(player => {
    const poster = player.querySelector('.video-player__poster');
    const btn = player.querySelector('.video-player__btn');
    const video = player.querySelector('.video-player__video');
    const src = player.dataset.video;
    function play() {
      if (!video.src) video.src = src;
      poster.style.display = 'none';
      btn.style.display = 'none';
      video.style.display = 'block';
      video.play();
    }
    poster.addEventListener('click', play);
    btn.addEventListener('click', play);
  });
</script>
