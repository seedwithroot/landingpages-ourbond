---
import QuoteForm from './QuoteForm.astro';

interface HeroProps {
  headline: string;
  subheadline?: string;
  ctaText: string;
  ctaUrl?: string;
  heroImage?: string;
  showForm?: boolean;
  showCta?: boolean;
  appButtons?: { apple?: string; google?: string };
  location?: string;
  trustLine?: string;
  pattern?: 'f-shaped' | 'z-shaped' | 'minimal';
}

const { 
  headline,
  subheadline,
  ctaText,
  ctaUrl = '#',
  heroImage,
  showForm = false,
  showCta = true,
  appButtons,
  location,
  trustLine,
  pattern = 'f-shaped'
} = Astro.props as HeroProps;
---

<section class={`hero hero-${pattern}`}>
  <div class="hero-container">
    <div class="hero-wrapper">
      <!-- Left Column: Content -->
      <div class="hero-content-column">
        <h1 class="hero-headline">{headline}</h1>
        {subheadline && <p class="hero-subheadline">{subheadline}</p>}
        {appButtons && (
          <div class="hero-app-buttons">
            {appButtons.apple && <img src="/buttons/apple-light.png" alt="Download on the App Store" style="height: 48px; width: auto;" />}
            {appButtons.google && <img src="/buttons/google-light.png" alt="Get it on Google Play" style="height: 48px; width: auto;" />}
          </div>
        )}
        <div class="hero-cta-wrapper">
          {showCta && <a href={ctaUrl} class="cta-primary">{ctaText}</a>}
          {trustLine && <p class="trust-line">{trustLine}</p>}
        </div>
      </div>
      
      <!-- Right Column: Form or Image -->
      {showForm ? (
        <div class="hero-form-column">
          <QuoteForm location={location} variant="compact" />
        </div>
      ) : heroImage ? (
        <div class="hero-image-column">
          <img src={heroImage} alt="Product Preview" class="hero-image" />
        </div>
      ) : null}
    </div>
  </div>
</section>

<style>
  /* Hero Section - F-Shape Blueprint */
  .hero {
    padding: 4rem 0;
    background: var(--near-black);
    position: relative;
    overflow: hidden;
  }
  
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 50%, rgba(37,99,235,0.04) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 10% 80%, rgba(14,165,233,0.03) 0%, transparent 60%);
    pointer-events: none;
  }
  
  /* Container - Max width with padding */
  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }
  
  /* Wrapper - Two Column Grid */
  .hero-wrapper {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  
  /* Desktop: Side-by-side columns */
  @media (min-width: 968px) {
    .hero-wrapper {
      grid-template-columns: 1.2fr 0.8fr;
      gap: 4rem;
    }
  }
  
  /* Left Column: Content */
  .hero-content-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .hero-headline {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1;
    color: var(--text);
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 0;
  }
  
  .hero-subheadline {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--muted);
    line-height: 1.6;
    font-weight: 400;
    max-width: 560px;
    margin: 0;
  }
  
  .hero-app-buttons {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .hero-cta-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
    margin-top: 0.5rem;
  }
  
  .trust-line {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-light);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0;
  }
  
  /* Right Column: Form */
  .hero-form-column {
    width: 100%;
  }
  
  @media (min-width: 968px) {
    .hero-form-column {
      position: sticky;
      top: 120px;
    }
  }
  
  /* Right Column: Image */
  .hero-image-column {
    width: 100%;
  }
  
  .hero-image {
    width: 100%;
    height: auto;
    border: 2px solid var(--border);
    box-shadow: var(--shadow-lg);
  }
  
  /* Mobile */
  @media (max-width: 967px) {
    .hero {
      padding: 3rem 0;
    }
    
    .hero-wrapper {
      gap: 2.5rem;
    }
    
    .hero-headline {
      font-size: 2rem;
    }
    
    .hero-cta-wrapper .cta-primary {
      width: 100%;
      text-align: center;
      justify-content: center;
    }
  }
</style>
