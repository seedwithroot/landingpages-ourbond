---
interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "OurBond Templates"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Admin Navigation -->
    <nav class="admin-nav">
      <div class="admin-container">
        <div class="nav-content">
          <div class="logo-section">
            <img src="https://www.ourbond.com/wp-content/themes/bond/src/images/bond-logo.svg" alt="OurBond" class="logo" />
          </div>
          <div class="nav-links">
            <a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>Templates</a>
          </div>
        </div>
      </div>
    </nav>

    <slot />
  </body>
</html>

<style is:global>
  :root {
    --admin-bg: #f5f7fa;
    --admin-surface: #ffffff;
    --admin-border: #e1e4e8;
    --admin-text: #24292e;
    --admin-text-muted: #6a737d;
    --admin-primary: #0366d6;
    --admin-primary-hover: #0256c4;
    --admin-success: #28a745;
    --admin-danger: #d73a49;
    --admin-warning: #f59e0b;
    --admin-shadow: 0 1px 3px rgba(0, 0, 0, 0.12), 0 1px 2px rgba(0, 0, 0, 0.08);
    --admin-shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }
  
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  
  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--admin-bg);
    color: var(--admin-text);
    line-height: 1.6;
    min-height: 100vh;
  }
  
  .admin-nav {
    background: var(--admin-surface);
    border-bottom: 1px solid var(--admin-border);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: var(--admin-shadow);
  }
  
  .admin-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 4rem;
  }
  
  .logo-section {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .logo {
    height: 32px;
    width: auto;
  }
  
  .admin-badge {
    background: var(--admin-primary);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .nav-links {
    display: flex;
    gap: 0.5rem;
  }
  
  .nav-links a {
    padding: 0.5rem 1rem;
    color: var(--admin-text-muted);
    text-decoration: none;
    font-weight: 500;
    border-radius: 6px;
    transition: background-color 0.2s, color 0.2s;
  }
  
  .nav-links a:hover {
    background: var(--admin-bg);
    color: var(--admin-text);
  }
  
  .nav-links a.active {
    background: var(--admin-primary);
    color: white;
  }
  
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .admin-card {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: var(--admin-shadow);
  }
  
  .admin-grid {
    display: grid;
    gap: 1.5rem;
  }
  
  @media (min-width: 768px) {
    .admin-grid-2 {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .admin-grid-3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.1s;
  }
  
  .btn:active {
    transform: translateY(1px);
  }
  
  .btn-primary {
    background: var(--admin-primary);
    color: white;
  }
  
  .btn-primary:hover {
    background: var(--admin-primary-hover);
  }
  
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .badge-light {
    background: #e3f2fd;
    color: #1976d2;
  }
  
  .badge-dark {
    background: #1a1a1a;
    color: #f5f5f5;
  }
</style>
