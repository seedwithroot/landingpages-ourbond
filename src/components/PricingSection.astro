---
/**
 * PricingSection — universal pricing module with monthly/annual toggle.
 *
 * Usage:
 *   import PricingSection from '../components/PricingSection.astro';
 *   <PricingSection plans={plans} />
 *
 * Each plan object:
 *   id:           string  — unique key used for scoping (e.g. "ind", "fam")
 *   name:         string  — display name
 *   subtitle?:    string  — shown below name (e.g. "Up to 5 members")
 *   featured?:    boolean — shows "Most popular" banner + blue border
 *   ctaText?:     string  — CTA button label (default: "Try 30 days free")
 *   ctaHref?:     string  — CTA button href (default: "#")
 *   featuresLabel?: string — label above feature list
 *   features:     string[] — feature bullet lines
 *   monthly:      { was?: string; price: string; unit?: string }
 *   annual:       { was?: string; price: string; unit?: string; billed?: string }
 */

export interface PricingPlan {
  id: string;
  name: string;
  subtitle?: string;
  featured?: boolean;
  ctaText?: string;
  ctaHref?: string;
  ctaHrefMonthly?: string;
  ctaHrefAnnual?: string;
  featuresLabel?: string;
  features: string[];
  monthly: {
    was?: string;
    price: string;
    unit?: string;
  };
  annual: {
    was?: string;
    price: string;
    unit?: string;
    billed?: string;
  };
}

export interface Props {
  /** Eyebrow label above headline */
  eyebrow?: string;
  /** Main heading */
  headline?: string;
  /** Subheading below headline */
  subheadline?: string;
  /** Badge text on the annual toggle button */
  saveBadgeText?: string;
  /** Pricing plans */
  plans: PricingPlan[];
  /** Background color */
  bg?: string;
}

const {
  eyebrow = 'Pricing',
  headline = 'Simple, transparent pricing.',
  subheadline = 'Cancel any time. No contracts.',
  saveBadgeText = 'Save up to 10%',
  plans,
  bg = '#f5f4f1',
} = Astro.props;

// Unique ID scopes this instance so multiple sections can coexist on a page.
const uid = `ps-${Math.random().toString(36).slice(2, 8)}`;
---

<section
  id="pricing"
  data-pricing-uid={uid}
  style={`background: ${bg}; padding: 3rem 0; position: relative;`}
>
  <div class="pricing-container">
    {eyebrow && (
      <p class="pricing-eyebrow">
        {eyebrow}
      </p>
    )}
    {headline && (
      <h2 class="pricing-headline">
        {headline}
      </h2>
    )}
    {subheadline && (
      <p class="pricing-subheadline">{subheadline}</p>
    )}

    <!-- Toggle -->
    <div class="pricing-toggle">
      <button
        data-period-btn="monthly"
        class="pricing-toggle-btn active"
      >
        Monthly
      </button>
      <button
        data-period-btn="annual"
        class="pricing-toggle-btn"
      >
        Annually
        {saveBadgeText && (
          <span class="pricing-save-badge">
            {saveBadgeText}
          </span>
        )}
      </button>
    </div>

    <!-- Plan cards -->
    <div class="pricing-cards">
      {plans.map(plan => (
        <div class={`pricing-card ${plan.featured ? 'pricing-card-featured' : ''}`}>
          {plan.featured && (
            <div class="pricing-card-badge">
              Most popular
            </div>
          )}
          <div class="pricing-card-content">
            <p class="pricing-card-name">{plan.name}</p>
            {plan.subtitle && (
              <p class="pricing-card-subtitle">{plan.subtitle}</p>
            )}

            <!-- Monthly price block -->
            <div data-price-monthly class="pricing-price-block">
              {plan.monthly.was && (
                <p class="pricing-was-price">{plan.monthly.was}</p>
              )}
              <p class="pricing-price">
                {plan.monthly.price}
                <span class="pricing-unit">{plan.monthly.unit ?? '/mo'}</span>
              </p>
            </div>

            <!-- Annual price block -->
            <div data-price-annual class="pricing-price-block" style="display: none;">
              {plan.annual.was && (
                <p class="pricing-was-price">{plan.annual.was}</p>
              )}
              <p class="pricing-price">
                {plan.annual.price}
                <span class="pricing-unit">{plan.annual.unit ?? '/mo'}</span>
              </p>
              {plan.annual.billed && (
                <p class="pricing-billed">{plan.annual.billed}</p>
              )}
            </div>

            {plan.featuresLabel && (
              <p class="pricing-features-label">{plan.featuresLabel}</p>
            )}
            <ul class="pricing-features">
              {plan.features.map(f => (
                <li class="pricing-feature">
                  <span class="pricing-check">&#10003;</span>
                  {f}
                </li>
              ))}
            </ul>

            <a
              data-cta-link
              data-href-monthly={plan.ctaHrefMonthly ?? plan.ctaHref ?? '#'}
              data-href-annual={plan.ctaHrefAnnual ?? plan.ctaHref ?? '#'}
              href={plan.ctaHrefMonthly ?? plan.ctaHref ?? '#'}
              class={`pricing-cta ${plan.featured ? 'pricing-cta-featured' : ''}`}
            >
              {plan.ctaText ?? 'Try 30 days free'}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-container {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 1rem;
    text-align: center;
  }

  .pricing-eyebrow {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #2563eb;
    margin: 0 0 0.75rem;
  }

  .pricing-headline {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 800;
    color: #111;
    line-height: 1.15;
    margin: 0 0 0.5rem;
  }

  .pricing-subheadline {
    font-size: clamp(0.9375rem, 2vw, 1.0625rem);
    color: #555;
    margin: 0 0 2rem;
  }

  .pricing-toggle {
    display: inline-flex;
    background: #fff;
    border-radius: 999px;
    padding: 0.25rem;
    border: 1px solid #e5e5e5;
    margin-bottom: 2.5rem;
    gap: 0;
  }

  .pricing-toggle-btn {
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    background: transparent;
    color: #555;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: background 0.15s, color 0.15s;
  }

  .pricing-toggle-btn.active {
    background: #111;
    color: #fff;
  }

  .pricing-save-badge {
    font-size: 0.6875rem;
    font-weight: 700;
    background: #dcfce7;
    color: #166534;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .pricing-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    text-align: left;
    align-items: stretch;
  }

  .pricing-card {
    background: #fff;
    border-radius: 20px;
    padding: 1.5rem;
    border: 1px solid #e5e5e5;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .pricing-card-featured {
    border: 2px solid #2563eb;
  }

  .pricing-card-badge {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background: #2563eb;
    text-align: center;
    padding: 0.4rem;
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.04em;
  }

  .pricing-card-content {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .pricing-card-featured .pricing-card-content {
    margin-top: 1.5rem;
  }

  .pricing-card-name {
    font-size: 1.25rem;
    font-weight: 800;
    color: #111;
    margin: 0 0 0.375rem;
  }

  .pricing-card-subtitle {
    font-size: 0.875rem;
    color: #555;
    margin: 0 0 1rem;
  }

  .pricing-price-block {
    margin-bottom: 1.5rem;
  }

  .pricing-was-price {
    font-size: 0.8125rem;
    color: #aaa;
    text-decoration: line-through;
    margin: 0 0 0.125rem;
  }

  .pricing-price {
    font-size: 2rem;
    font-weight: 800;
    color: #111;
    margin: 0;
    line-height: 1;
  }

  .pricing-unit {
    font-size: 0.9375rem;
    font-weight: 500;
    color: #555;
  }

  .pricing-billed {
    font-size: 0.8125rem;
    color: #166534;
    font-weight: 600;
    margin: 0.25rem 0 0;
  }

  .pricing-features-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: #111;
    margin: 0 0 0.75rem;
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .pricing-feature {
    font-size: 0.875rem;
    color: #333;
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
  }

  .pricing-check {
    color: #2563eb;
    font-weight: 700;
    flex-shrink: 0;
  }

  .pricing-cta {
    display: block;
    background: #111;
    color: #fff;
    text-align: center;
    font-size: 0.9375rem;
    font-weight: 700;
    padding: 0.875rem 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    margin-top: auto;
    transition: background 0.2s;
  }

  .pricing-cta:hover {
    background: #000;
  }

  .pricing-cta-featured {
    background: #2563eb;
  }

  .pricing-cta-featured:hover {
    background: #1d4ed8;
  }

  @media (min-width: 640px) {
    .pricing-container {
      padding: 0 2rem;
    }

    .pricing-toggle-btn {
      font-size: 0.9375rem;
      padding: 0.5rem 1.5rem;
    }

    .pricing-save-badge {
      font-size: 0.75rem;
    }

    .pricing-card {
      padding: 2rem;
    }

    .pricing-card-name {
      font-size: 1.375rem;
    }

    .pricing-card-subtitle {
      font-size: 0.9rem;
    }

    .pricing-price {
      font-size: 2.25rem;
    }

    .pricing-unit {
      font-size: 1rem;
    }

    .pricing-feature {
      font-size: 0.9375rem;
    }

    .pricing-features {
      margin: 0 0 1.75rem;
    }

    .pricing-cta {
      font-size: 1rem;
    }
  }

  @media (min-width: 768px) {
    .pricing-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .pricing-cards {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }
  }
</style>

<script is:inline define:vars={{ uid }}>
  (function () {
    var section = document.querySelector('[data-pricing-uid="' + uid + '"]');
    if (!section) return;

    var mBtn = section.querySelector('[data-period-btn="monthly"]');
    var aBtn = section.querySelector('[data-period-btn="annual"]');

    function applyPeriod(isAnnual) {
      section.querySelectorAll('[data-price-monthly]').forEach(function (el) {
        el.style.display = isAnnual ? 'none' : 'block';
      });
      section.querySelectorAll('[data-price-annual]').forEach(function (el) {
        el.style.display = isAnnual ? 'block' : 'none';
      });
      section.querySelectorAll('[data-cta-link]').forEach(function (link) {
        var monthlyHref = link.getAttribute('data-href-monthly');
        var annualHref = link.getAttribute('data-href-annual');
        link.setAttribute('href', isAnnual ? annualHref : monthlyHref);
      });
      
      if (isAnnual) {
        mBtn.classList.remove('active');
        aBtn.classList.add('active');
      } else {
        mBtn.classList.add('active');
        aBtn.classList.remove('active');
      }
    }

    mBtn.addEventListener('click', function () { applyPeriod(false); });
    aBtn.addEventListener('click', function () { applyPeriod(true); });
  })();
</script>
