---
/**
 * PageReview — client annotation overlay.
 *
 * Activates only when ?review=true is present in the URL.
 * Comments are stored in localStorage, keyed by page path.
 *
 * Usage:
 *   Share any page URL with ?review=true appended.
 *   The reviewer types their name, clicks "+ Add Comment",
 *   then clicks anywhere on the page to drop a numbered pin.
 *   "Copy Comments" exports all notes as plain text.
 */
---

<div id="pr-host" style="display:none"></div>

<script>
(function () {
  'use strict';

  if (!new URLSearchParams(location.search).has('review')) return;

  // ─── Storage ──────────────────────────────────────────────────────────────
  const STORAGE_KEY = 'pr:' + location.pathname;
  const state = {
    comments: [],
    nextId: 1,
    placing: false,
    panelOpen: true,
  };

  try {
    const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
    if (saved && Array.isArray(saved.comments)) {
      state.comments = saved.comments;
      state.nextId = state.comments.length
        ? Math.max(...state.comments.map((c) => c.num)) + 1
        : 1;
    }
  } catch (_) {}

  function persist() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ comments: state.comments }));
  }

  // ─── Styles ───────────────────────────────────────────────────────────────
  const css = `
    body { position: relative !important; }

    /* ── Pin layer ── */
    #pr-pin-layer {
      position: absolute; top: 0; left: 0; width: 100%;
      pointer-events: none; z-index: 9000;
    }

    /* ── Placing crosshair overlay ── */
    #pr-placing-overlay {
      position: fixed; inset: 0; z-index: 9001;
      cursor: crosshair;
      background: rgba(37,99,235,0.07);
      display: none;
    }
    #pr-placing-overlay.active { display: block; }
    #pr-placing-hint {
      position: fixed; top: 20px; left: 50%; transform: translateX(-50%);
      background: rgba(15,15,30,0.85); color: #fff;
      padding: 10px 20px; border-radius: 8px;
      font: 13px/1 'Barlow', sans-serif; white-space: nowrap;
      pointer-events: none; z-index: 9002;
    }

    /* ── Pin ── */
    .pr-pin {
      position: absolute;
      width: 30px; height: 30px; margin-top: -30px; margin-left: -8px;
      border-radius: 50% 50% 50% 0; transform: rotate(-45deg);
      background: #f59e0b; border: 2px solid #fff;
      box-shadow: 0 2px 8px rgba(0,0,0,0.3);
      cursor: pointer; pointer-events: all;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s, transform 0.15s;
    }
    .pr-pin:hover { background: #d97706; }
    .pr-pin.active-pin { background: #2563eb; }
    .pr-pin .pr-num {
      transform: rotate(45deg);
      font: 700 11px/1 'Barlow', sans-serif;
      color: #fff; user-select: none;
    }

    /* ── Comment bubble ── */
    .pr-bubble {
      position: absolute; top: 10px; left: 32px;
      background: #fff; border: 1px solid #e5e7eb;
      border-radius: 10px; padding: 12px 14px;
      min-width: 230px; max-width: 300px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.14);
      z-index: 9002; font-family: 'Barlow', sans-serif;
      font-size: 13px; pointer-events: all;
      display: none;
    }
    .pr-bubble.visible { display: block; }
    .pr-bubble .prb-meta { display: flex; align-items: baseline; gap: 6px; }
    .pr-bubble .prb-author { font-weight: 700; color: #1e1e2e; }
    .pr-bubble .prb-date { font-size: 11px; color: #9ca3af; }
    .pr-bubble .prb-text { margin-top: 7px; color: #374151; line-height: 1.55; }
    .pr-bubble .prb-del {
      margin-top: 9px; font-size: 11px; cursor: pointer;
      color: #ef4444; background: none; border: none; padding: 0;
      font-family: inherit;
    }
    .pr-bubble .prb-del:hover { color: #b91c1c; text-decoration: underline; }

    /* ── Toolbar ── */
    #pr-toolbar {
      position: fixed; bottom: 20px; right: 20px; z-index: 9999;
      background: #1e1e2e; border-radius: 12px;
      padding: 10px 14px; display: flex; align-items: center; gap: 10px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.35);
      font-family: 'Barlow', sans-serif; font-size: 13px;
      flex-wrap: wrap; max-width: calc(100vw - 40px);
    }
    #pr-toolbar .pr-reviewer-label {
      color: #9ca3af; font-size: 12px; white-space: nowrap;
    }
    #pr-name-input {
      background: transparent; border: 1px solid #374151;
      color: #fff; border-radius: 6px; padding: 5px 8px;
      font: 12px 'Barlow', sans-serif; width: 110px; outline: none;
    }
    #pr-name-input:focus { border-color: #2563eb; }
    #pr-name-input::placeholder { color: #6b7280; }
    #pr-toolbar button {
      background: #374151; border: none; color: #d1d5db;
      border-radius: 6px; padding: 6px 12px; cursor: pointer;
      font: 12px 'Barlow', sans-serif; white-space: nowrap;
      transition: background 0.15s, color 0.15s;
    }
    #pr-toolbar button:hover { background: #4b5563; color: #fff; }
    #pr-btn-add { background: #2563eb !important; color: #fff !important; }
    #pr-btn-add:hover { background: #1d4ed8 !important; }
    #pr-btn-add.placing { background: #ef4444 !important; }
    #pr-btn-add.placing:hover { background: #b91c1c !important; }
    #pr-count-badge {
      background: #f59e0b; color: #fff; border-radius: 999px;
      padding: 2px 8px; font: 700 11px 'Barlow', sans-serif;
      min-width: 22px; text-align: center;
    }

    /* ── Side panel ── */
    #pr-panel {
      position: fixed; right: 0; top: 0; bottom: 0; width: 310px;
      background: #fff; border-left: 1px solid #e5e7eb;
      box-shadow: -4px 0 24px rgba(0,0,0,0.12);
      z-index: 9998; display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform 0.25s ease;
      font-family: 'Barlow', sans-serif;
    }
    #pr-panel.open { transform: translateX(0); }
    #pr-panel-head {
      background: #1e1e2e; color: #fff; padding: 14px 16px;
      font: 600 14px 'Barlow', sans-serif;
      display: flex; justify-content: space-between; align-items: center;
      flex-shrink: 0;
    }
    #pr-panel-head button {
      background: none; border: none; color: #9ca3af;
      font-size: 20px; line-height: 1; cursor: pointer; padding: 0;
    }
    #pr-panel-head button:hover { color: #fff; }
    #pr-panel-body { overflow-y: auto; flex: 1; }
    .pr-empty {
      padding: 36px 20px; text-align: center;
      color: #9ca3af; font-size: 13px; line-height: 1.7;
    }
    .pr-ci {
      padding: 12px 16px; border-bottom: 1px solid #f3f4f6;
      cursor: pointer; transition: background 0.1s;
    }
    .pr-ci:hover { background: #f9fafb; }
    .pr-ci-head { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; }
    .pr-ci-num {
      width: 22px; height: 22px; border-radius: 50%;
      background: #f59e0b; color: #fff;
      font: 700 11px 'Barlow', sans-serif;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .pr-ci-author { font-weight: 700; font-size: 13px; color: #1e1e2e; }
    .pr-ci-date { font-size: 11px; color: #9ca3af; margin-left: auto; }
    .pr-ci-text { font-size: 13px; color: #374151; line-height: 1.55; padding-left: 30px; }
    .pr-ci-del {
      display: block; margin: 6px 0 0 30px;
      font-size: 11px; color: #ef4444; cursor: pointer;
      background: none; border: none; padding: 0;
      font-family: inherit;
    }
    .pr-ci-del:hover { text-decoration: underline; }

    /* ── Comment input modal ── */
    #pr-modal {
      position: fixed; inset: 0; z-index: 10000;
      background: rgba(0,0,0,0.45);
      display: none; align-items: center; justify-content: center;
    }
    #pr-modal.visible { display: flex; }
    #pr-modal-box {
      background: #fff; border-radius: 12px; padding: 24px;
      width: 380px; max-width: calc(100vw - 40px);
      box-shadow: 0 20px 60px rgba(0,0,0,0.25);
      font-family: 'Barlow', sans-serif;
    }
    #pr-modal-box h3 { margin: 0 0 14px; font-size: 16px; color: #1e1e2e; }
    #pr-comment-ta {
      width: 100%; box-sizing: border-box; padding: 10px 12px;
      border: 1px solid #d1d5db; border-radius: 8px;
      font: 14px/1.55 'Barlow', sans-serif;
      resize: vertical; min-height: 90px; outline: none;
    }
    #pr-comment-ta:focus { border-color: #2563eb; }
    #pr-modal-hint {
      font-size: 11px; color: #9ca3af; margin-top: 6px;
    }
    #pr-modal-actions {
      display: flex; gap: 8px; justify-content: flex-end; margin-top: 14px;
    }
    #pr-modal-actions button {
      border: none; border-radius: 6px; padding: 8px 18px;
      cursor: pointer; font: 13px 'Barlow', sans-serif;
    }
    #pr-btn-cancel-modal { background: #f3f4f6; color: #374151; }
    #pr-btn-cancel-modal:hover { background: #e5e7eb; }
    #pr-btn-save-modal { background: #2563eb; color: #fff; }
    #pr-btn-save-modal:hover { background: #1d4ed8; }
  `;

  const styleEl = document.createElement('style');
  styleEl.textContent = css;
  document.head.appendChild(styleEl);

  // ─── DOM scaffolding ──────────────────────────────────────────────────────

  // 1. Pin layer
  const pinLayer = document.createElement('div');
  pinLayer.id = 'pr-pin-layer';
  document.body.appendChild(pinLayer);

  // 2. Placing overlay
  const placingOverlay = document.createElement('div');
  placingOverlay.id = 'pr-placing-overlay';
  const placingHint = document.createElement('div');
  placingHint.id = 'pr-placing-hint';
  placingHint.textContent = 'Click anywhere to drop a comment — Esc to cancel';
  placingOverlay.appendChild(placingHint);
  document.body.appendChild(placingOverlay);

  // 3. Toolbar
  const toolbar = document.createElement('div');
  toolbar.id = 'pr-toolbar';
  toolbar.innerHTML = `
    <span class="pr-reviewer-label">Reviewing as:</span>
    <input id="pr-name-input" type="text" placeholder="Your name" autocomplete="off" />
    <button id="pr-btn-add">+ Add Comment</button>
    <span id="pr-count-badge">0</span>
    <button id="pr-btn-panel">☰ Comments</button>
    <button id="pr-btn-copy">Copy All</button>
  `;
  document.body.appendChild(toolbar);

  // 4. Input modal
  const modal = document.createElement('div');
  modal.id = 'pr-modal';
  modal.innerHTML = `
    <div id="pr-modal-box">
      <h3>Add a comment</h3>
      <textarea id="pr-comment-ta" placeholder="Describe your feedback or requested change…"></textarea>
      <div id="pr-modal-hint">Tip: Ctrl+Enter to save</div>
      <div id="pr-modal-actions">
        <button id="pr-btn-cancel-modal">Cancel</button>
        <button id="pr-btn-save-modal">Save Comment</button>
      </div>
    </div>
  `;
  document.body.appendChild(modal);

  // 5. Side panel
  const panel = document.createElement('div');
  panel.id = 'pr-panel';
  panel.innerHTML = `
    <div id="pr-panel-head">
      <span>Page Comments</span>
      <button id="pr-panel-close" aria-label="Close">×</button>
    </div>
    <div id="pr-panel-body"></div>
  `;
  document.body.appendChild(panel);

  // ─── Helpers ──────────────────────────────────────────────────────────────

  function esc(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function docDimensions() {
    return {
      w: Math.max(document.body.scrollWidth, document.documentElement.scrollWidth),
      h: Math.max(document.body.scrollHeight, document.documentElement.scrollHeight),
    };
  }

  // ─── Renderer ────────────────────────────────────────────────────────────

  function render() {
    // Update badge
    document.getElementById('pr-count-badge').textContent = state.comments.length;

    // Update pin layer height
    const { h } = docDimensions();
    pinLayer.style.height = h + 'px';
    pinLayer.innerHTML = '';

    state.comments.forEach((c) => {
      const wrap = document.createElement('div');
      wrap.style.cssText = `position:absolute;left:${c.x}%;top:${c.y}%;`;

      const pin = document.createElement('div');
      pin.className = 'pr-pin';
      pin.dataset.id = c.id;
      pin.innerHTML = `<span class="pr-num">${c.num}</span>`;

      const bubble = document.createElement('div');
      bubble.className = 'pr-bubble';
      bubble.innerHTML = `
        <div class="prb-meta">
          <span class="prb-author">${esc(c.author)}</span>
          <span class="prb-date">${esc(c.date)}</span>
        </div>
        <div class="prb-text">${esc(c.text)}</div>
        <button class="prb-del" data-id="${c.id}">Delete comment</button>
      `;

      pin.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = bubble.classList.contains('visible');
        closeAllBubbles();
        if (!isOpen) {
          bubble.classList.add('visible');
          pin.classList.add('active-pin');
        }
      });

      bubble.querySelector('.prb-del').addEventListener('click', (e) => {
        e.stopPropagation();
        deleteComment(c.id);
      });

      wrap.appendChild(pin);
      wrap.appendChild(bubble);
      pinLayer.appendChild(wrap);
    });

    renderPanel();
  }

  function renderPanel() {
    const body = document.getElementById('pr-panel-body');
    if (state.comments.length === 0) {
      body.innerHTML = `<div class="pr-empty">No comments yet.<br/>Click <strong>+ Add Comment</strong> and then<br/>click anywhere on the page.</div>`;
      return;
    }
    body.innerHTML = state.comments
      .map(
        (c) => `
      <div class="pr-ci" data-id="${c.id}">
        <div class="pr-ci-head">
          <div class="pr-ci-num">${c.num}</div>
          <span class="pr-ci-author">${esc(c.author)}</span>
          <span class="pr-ci-date">${esc(c.date)}</span>
        </div>
        <div class="pr-ci-text">${esc(c.text)}</div>
        <button class="pr-ci-del" data-id="${c.id}">Delete</button>
      </div>`
      )
      .join('');

    body.querySelectorAll('.pr-ci').forEach((el) => {
      el.addEventListener('click', (e) => {
        if (e.target.closest('.pr-ci-del')) return;
        const c = state.comments.find((x) => x.id === parseInt(el.dataset.id));
        if (!c) return;
        const { h } = docDimensions();
        window.scrollTo({ top: (c.y / 100) * h - 160, behavior: 'smooth' });
      });
    });

    body.querySelectorAll('.pr-ci-del').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        deleteComment(parseInt(btn.dataset.id));
      });
    });
  }

  function closeAllBubbles() {
    document.querySelectorAll('.pr-bubble.visible').forEach((b) => b.classList.remove('visible'));
    document.querySelectorAll('.pr-pin.active-pin').forEach((p) => p.classList.remove('active-pin'));
  }

  // ─── Comment actions ─────────────────────────────────────────────────────

  let pendingCoords = null;

  function startPlacing() {
    state.placing = true;
    placingOverlay.classList.add('active');
    document.getElementById('pr-btn-add').classList.add('placing');
    document.getElementById('pr-btn-add').textContent = '✕ Cancel';
  }

  function stopPlacing() {
    state.placing = false;
    placingOverlay.classList.remove('active');
    const btn = document.getElementById('pr-btn-add');
    btn.classList.remove('placing');
    btn.textContent = '+ Add Comment';
  }

  function deleteComment(id) {
    state.comments = state.comments.filter((c) => c.id !== id);
    persist();
    render();
  }

  function saveComment() {
    const text = document.getElementById('pr-comment-ta').value.trim();
    if (!text || !pendingCoords) return;

    const reviewer = document.getElementById('pr-name-input').value.trim() || 'Reviewer';
    state.comments.push({
      id: Date.now(),
      num: state.nextId++,
      x: pendingCoords.x,
      y: pendingCoords.y,
      text,
      author: reviewer,
      date: new Date().toLocaleString('en-US', {
        month: 'short', day: 'numeric',
        hour: '2-digit', minute: '2-digit',
      }),
    });

    persist();
    pendingCoords = null;
    modal.classList.remove('visible');
    render();
  }

  function copyComments() {
    if (state.comments.length === 0) {
      alert('No comments to copy yet.');
      return;
    }
    const lines = [
      `Page Review — ${location.href.split('?')[0]}`,
      `Exported: ${new Date().toLocaleString()}`,
      `Total comments: ${state.comments.length}`,
      '',
    ];
    state.comments.forEach((c) => {
      lines.push(`[${c.num}] ${c.author} — ${c.date}`);
      lines.push(c.text);
      lines.push('');
    });
    navigator.clipboard.writeText(lines.join('\n')).then(() => {
      const btn = document.getElementById('pr-btn-copy');
      const orig = btn.textContent;
      btn.textContent = '✓ Copied!';
      setTimeout(() => { btn.textContent = orig; }, 2200);
    });
  }

  // ─── Event wiring ─────────────────────────────────────────────────────────

  // Restore reviewer name
  const nameInput = document.getElementById('pr-name-input');
  nameInput.value = localStorage.getItem('pr-reviewer-name') || '';
  nameInput.addEventListener('input', () => {
    localStorage.setItem('pr-reviewer-name', nameInput.value);
  });

  document.getElementById('pr-btn-add').addEventListener('click', () => {
    if (state.placing) { stopPlacing(); } else { startPlacing(); }
  });

  document.getElementById('pr-btn-panel').addEventListener('click', () => {
    state.panelOpen = !state.panelOpen;
    panel.classList.toggle('open', state.panelOpen);
  });

  document.getElementById('pr-panel-close').addEventListener('click', () => {
    state.panelOpen = false;
    panel.classList.remove('open');
  });

  document.getElementById('pr-btn-copy').addEventListener('click', copyComments);

  // Placing overlay click → open modal
  placingOverlay.addEventListener('click', (e) => {
    const { w, h } = docDimensions();
    pendingCoords = {
      x: parseFloat((((e.clientX + window.scrollX) / w) * 100).toFixed(3)),
      y: parseFloat((((e.clientY + window.scrollY) / h) * 100).toFixed(3)),
    };
    stopPlacing();
    document.getElementById('pr-comment-ta').value = '';
    modal.classList.add('visible');
    setTimeout(() => document.getElementById('pr-comment-ta').focus(), 40);
  });

  // Modal actions
  document.getElementById('pr-btn-save-modal').addEventListener('click', saveComment);
  document.getElementById('pr-btn-cancel-modal').addEventListener('click', () => {
    modal.classList.remove('visible');
    pendingCoords = null;
  });
  document.getElementById('pr-comment-ta').addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) saveComment();
  });

  // Close bubbles on outside click
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.pr-pin') && !e.target.closest('.pr-bubble')) {
      closeAllBubbles();
    }
  });

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    if (modal.classList.contains('visible')) {
      modal.classList.remove('visible');
      pendingCoords = null;
      return;
    }
    stopPlacing();
    closeAllBubbles();
  });

  // Resize → refresh pin layer height
  window.addEventListener('resize', () => {
    const { h } = docDimensions();
    pinLayer.style.height = h + 'px';
  });

  // Open panel by default on load
  panel.classList.add('open');

  // Initial render
  render();
})();
</script>
