<script>
  document.querySelectorAll('.section--review a.card').forEach(card => {
    card.addEventListener('click', e => {
      const btn = e.target.closest('.btn-view, .btn-review');
      if (!btn) return;
      e.preventDefault();
      const href = card.getAttribute('href');
      if (btn.classList.contains('btn-review')) {
        window.open(href + '?review=true', '_blank');
      } else {
        window.open(href, '_blank');
      }
    });
  });
</script>
